<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/colorSurface"
    android:padding="20dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🎲 Бросок кубиков"
        android:textSize="20sp"
        android:textColor="@color/colorAccentGold"
        android:textStyle="bold"
        android:fontFamily="serif"
        android:gravity="center"
        android:layout_marginBottom="16dp"/>

    <!-- Standard dice row 1 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <Button android:id="@+id/btnD4" android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:text="d4" android:backgroundTint="@color/colorDicePurple" android:textColor="@color/white" android:textSize="16sp" android:textStyle="bold" android:layout_marginEnd="4dp"/>
        <Button android:id="@+id/btnD6" android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:text="d6" android:backgroundTint="@color/colorDicePurple" android:textColor="@color/white" android:textSize="16sp" android:textStyle="bold" android:layout_marginEnd="4dp"/>
        <Button android:id="@+id/btnD8" android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:text="d8" android:backgroundTint="@color/colorDicePurple" android:textColor="@color/white" android:textSize="16sp" android:textStyle="bold" android:layout_marginEnd="4dp"/>
        <Button android:id="@+id/btnD10" android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:text="d10" android:backgroundTint="@color/colorDicePurple" android:textColor="@color/white" android:textSize="16sp" android:textStyle="bold"/>
    </LinearLayout>

    <!-- Standard dice row 2 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <Button android:id="@+id/btnD12" android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:text="d12" android:backgroundTint="@color/colorPrimary" android:textColor="@color/white" android:textSize="16sp" android:textStyle="bold" android:layout_marginEnd="4dp"/>
        <Button android:id="@+id/btnD20" android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="2" android:text="⚔️ d20" android:backgroundTint="@color/colorPrimary" android:textColor="@color/white" android:textSize="18sp" android:textStyle="bold" android:layout_marginEnd="4dp"/>
        <Button android:id="@+id/btnD100" android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:text="d100" android:backgroundTint="@color/colorPrimary" android:textColor="@color/white" android:textSize="14sp" android:textStyle="bold"/>
    </LinearLayout>

    <!-- Custom notation -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Своя формула:"
        android:textColor="@color/colorSecondary"
        android:textStyle="bold"
        android:layout_marginBottom="4dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/etCustomDice"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="2d6+3, 1d20, 4d4-1"
            android:textColor="@color/colorOnBackground"
            android:textColorHint="@color/colorSystemGray"
            android:inputType="text"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btnRollCustom"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎲 Бросить"
            android:backgroundTint="@color/colorSecondary"
            android:textColor="@color/black"/>
    </LinearLayout>

</LinearLayout>
