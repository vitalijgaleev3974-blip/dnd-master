<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Предыстория" android:textColor="@color/colorSecondary" android:textStyle="bold" android:layout_marginBottom="4dp"/>
        <EditText
            android:id="@+id/etBackstory"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:background="@color/colorSurface"
            android:textColor="@color/colorOnBackground"
            android:hint="История персонажа..."
            android:textColorHint="@color/colorSystemGray"
            android:gravity="top"
            android:padding="8dp"
            android:layout_marginBottom="16dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Внешность" android:textColor="@color/colorSecondary" android:textStyle="bold" android:layout_marginBottom="4dp"/>
        <EditText
            android:id="@+id/etAppearance"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:background="@color/colorSurface"
            android:textColor="@color/colorOnBackground"
            android:hint="Описание внешности..."
            android:textColorHint="@color/colorSystemGray"
            android:gravity="top"
            android:padding="8dp"
            android:layout_marginBottom="16dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Заметки" android:textColor="@color/colorSecondary" android:textStyle="bold" android:layout_marginBottom="4dp"/>
        <EditText
            android:id="@+id/etNotes"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:background="@color/colorSurface"
            android:textColor="@color/colorOnBackground"
            android:hint="Свободные заметки..."
            android:textColorHint="@color/colorSystemGray"
            android:gravity="top"
            android:padding="8dp"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/btnSaveNotes"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="💾 Сохранить заметки"
            android:backgroundTint="@color/colorPrimary"
            android:textColor="@color/white"/>

    </LinearLayout>
</ScrollView>
